<UserControl x:Class="ui.StartScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ui"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="LightGray">
        <StackPanel Margin="20">
            <TextBlock Text="Choose a category" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <ListBox x:Name="lbSubjects" SelectionChanged="lbSubjects_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="200" Margin="15">
                            <Border ClipToBounds="True" Height="100" CornerRadius="10">
                                <Image Source="{Binding Photo}" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" Margin="5"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>                              
        </StackPanel>            
    </Grid>
</UserControl>
